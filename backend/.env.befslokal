# Befslokal – backend (brukes av docker compose)
PROJECT_NAME=Befslokal Backend
API_V1_STR=/api/v1
ENVIRONMENT=local

BACKEND_CORS_ORIGINS=http://localhost:3000
FRONTEND_URLS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/eiendom

SECRET_KEY=befs-super-secret-key-12345
ALLOW_SHARED_SECRET_BYPASS=true
ADMIN_EMAILS=admin@befslokal.no,admin@bufdir.no

USE_LOCAL_AI=true
LOCAL_AI_STATION_URL=http://ollama:11434/v1
LOCAL_MODEL_NAME=mistral

OPENAI_API_KEY=ollama-local-key
OPENAI_BASE_URL=http://ollama:11434/v1
OPENAI_MODEL=mistral
OPENAI_EMBEDDING_MODEL=nomic-embed-text

ENABLE_VECTOR_SEARCH=true
MAPBOX_ACCESS_TOKEN=
