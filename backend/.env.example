# Project
PROJECT_NAME="KNOWME Backend"
API_V1_STR="/api/v1"
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Database
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=knowme
# DATABASE_URL=postgresql+asyncpg://user:pass@host/db

# --- Befslokal (lokal Ollama/Mistral) – se ../docker-compose.yml ---
# USE_LOCAL_AI=true
# LOCAL_AI_STATION_URL=http://localhost:11434/v1
# LOCAL_MODEL_NAME=mistral
# OPENAI_API_KEY=ollama-local-key
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=mistral
# OPENAI_EMBEDDING_MODEL=nomic-embed-text
# ALLOW_SHARED_SECRET_BYPASS=true

# OpenAI (sky – kun hvis USE_LOCAL_AI=false)
OPENAI_API_KEY=placeholder
OPENAI_MODEL=gpt-4o-mini

# Mapbox (kart, geocoding, POI)
# Get your token at: https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here# Email (Resend) – for e-postverifisering og MFA-lenker
# Få API-nøkkel: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# For testing: bruk Resends testdomene (ingen domene-verifisering nødvendig)
# For produksjon: verifiser eget domene på resend.com/domains og bruk f.eks. noreply@befs.no
EMAIL_FROM=BEFS <onboarding@resend.dev>