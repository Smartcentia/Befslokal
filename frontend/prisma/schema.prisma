  status           String      @default("pending") @db.VarChar(20) // pending | approved | rejected
  collision_flag   Boolean     @default(false)
  match_method     String      @db.VarChar(50) // exact | heuristic | fuzzy | manual
  score            Decimal?    @db.Decimal(5, 2)
  confidence       String      @db.VarChar(20) // HIGH | MEDIUM | LOW
  run_id           String?     @db.VarChar(50)
  valid_from       DateTime    @default(now()) @db.Timestamptz(6)
  valid_to         DateTime?   @db.Timestamptz(6)
  approved_by      String?     @db.VarChar(100)
  approved_at      DateTime?   @db.Timestamptz(6)
  audit_metadata   Json?       @db.Json
  created_at       DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?   @default(now()) @db.Timestamptz(6)

  @@index([source_id], map: "idx_crosswalk_source")
  @@index([target_id], map: "idx_crosswalk_target")
  @@index([source_type], map: "idx_crosswalk_source_type")
  @@index([relation_type], map: "idx_crosswalk_relation")
  @@index([status], map: "idx_crosswalk_status")
  @@index([run_id], map: "idx_crosswalk_run")
}
