# Kopier til .env.local for lokal utvikling uten Docker:
#   cp .env.local.example .env.local

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_LOCAL_AUTH=true

# Valgfritt – kart
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Backend shared secret (må matche SECRET_KEY i backend/.env)
NEXT_PUBLIC_BACKEND_SECRET=befs-super-secret-key-12345
