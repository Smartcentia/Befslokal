{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "node --stack-size=65536 ./node_modules/typescript/lib/tsc.js --noEmit -p .",
    "postinstall": "prisma generate",
    "test": "vitest",
    "reset-password": "node --env-file=.env scripts/reset-password.mjs",
    "validate-costs2025": "python3 scripts/validate_costs2025.py"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.96.0",
    "@types/leaflet": "1.9.21",
    "@types/react-leaflet": "^2.8.3",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.26",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "1.9.4",
    "lucide-react": "^0.561.0",
    "mapbox-gl": "^3.8.0",
    "moment": "^2.30.1",
    "next": "16.0.10",
    "next-auth": "^4.24.13",
    "react": "19.2.1",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.1",
    "react-leaflet": "5.0.0",
    "react-map-gl": "^8.1.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/dagre": "^0.7.54",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "jsdom": "^27.4.0",
    "prisma": "5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.16"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^16.1.1"
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals"
    ],
    "rules": {
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }
      ],
      "react-hooks/exhaustive-deps": "warn",
      "react/jsx-no-comment-textnodes": "off",
      "react/no-unescaped-entities": "off",
      "prefer-const": "warn",
      "react-hooks/set-state-in-effect": "off",
      "@next/next/no-img-element": "warn"
    }
  }
}
